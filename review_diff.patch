+                "flex items-center gap-2 font-bold text-xs uppercase tracking-wider",
+                warnings.length > 0 ? "text-amber-800" : "text-green-800",
+              )}
+            >
+              {warnings.length > 0 ? <AlertTriangle className="h-4 w-4" /> : <CheckCircle2 className="h-4 w-4" />}
