+  convexQueryMock: vi.fn(),
+  convexMutationMock: vi.fn(),
+}))
+
+vi.mock("convex/browser", () => ({
+  ConvexHttpClient: class {
+    query = convexQueryMock
+    mutation = convexMutationMock
